#!/usr/bin/env bash

if ! command -v module >/dev/null 2>&1; then
  for module_init in /etc/profile.d/modules.sh /usr/share/Modules/init/bash /usr/share/lmod/lmod/init/bash; do
    if [[ -f "$module_init" ]]; then
      # shellcheck source=/dev/null
      source "$module_init"
      break
    fi
  done
fi

if ! command -v module >/dev/null 2>&1; then
  echo "ERROR: environment modules command is unavailable." >&2
  exit 1
fi

module purge
module use /cvmfs/oasis.opensciencegrid.org/jlab/scicomp/sw/el9/modulefiles
module load root/6.30.04-gcc11.4.0

set -euo pipefail

usage() {
  cat <<USAGE
Usage: $0 <kin> <bin_index>

Run MC for one E' bin at a time using the trial limit and target good-event
settings already stored in the kin input file.

Arguments:
  kin        One of: kin3_hms, kin4_hms, kinB_shms, kinC_shms
  bin_index  Zero-based E' bin index

USAGE
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -ne 2 ]]; then
  usage
  exit 1
fi

kin="$1"
bin_index="$2"

if ! [[ "$bin_index" =~ ^[0-9]+$ ]]; then
  echo "ERROR: bin_index must be a non-negative integer." >&2
  exit 2
fi

case "$kin" in
  kin3_hms|kin4_hms|kinB_shms|kinC_shms) ;;
  *)
    echo "ERROR: kin must be one of kin3_hms, kin4_hms, kinB_shms, kinC_shms." >&2
    exit 2
    ;;
esac

for d in runout worksim outfiles; do
  if [[ ! -e "$d" ]]; then
    mkdir -p "$d"
  fi
done

build_once() {
  (cd src && make clean && make)
  (cd util/root_tree && make clean && make)
}

resolve_bin() {
  local kin_name="$1"
  local idx="$2"
  local p_spec_mev="$3"

  python3 - "$kin_name" "$idx" "$p_spec_mev" <<'PY'
import sys
kin = sys.argv[1]
idx = int(sys.argv[2])
p_spec_mev = float(sys.argv[3])
p_spec_gev = p_spec_mev / 1000.0

edges_by_kin = {
    "kinC_shms": [2.09,2.11,2.13,2.15,2.17,2.19,2.21,2.23,2.25,2.27,2.29,2.31,2.33,2.35,2.37,2.39,2.41,2.43,2.45,2.47,2.49,2.51,2.53,2.55,2.57,2.59,2.61,2.63,2.65,2.67,2.69,2.71,2.73,2.75,2.77,2.79,2.81,2.83,2.85,2.87,2.89,2.91,2.93,2.95,2.97,2.99,3.01,3.03,3.05,3.07,3.09,3.11,3.13,3.15,3.17,3.19,3.21,3.23,3.25,3.27,3.29,3.31,3.33,3.35,3.37,3.39,3.41,3.43,3.45,3.47,3.49,3.51],
    "kinB_shms": [2.79,2.81,2.83,2.85,2.87,2.89,2.91,2.93,2.95,2.97,2.99,3.01,3.03,3.05,3.07,3.09,3.11,3.13,3.15,3.17,3.19,3.21,3.23,3.25,3.27,3.29,3.31,3.33,3.35,3.37,3.39,3.41,3.43,3.45,3.47,3.49,3.51,3.53,3.55,3.57,3.59,3.61,3.63,3.65,3.67,3.69,3.71,3.73,3.75,3.77,3.79,3.81,3.83,3.85,3.87,3.89,3.91,3.93,3.95,3.97,3.99,4.01,4.03,4.05,4.07,4.09,4.11,4.13,4.15,4.17,4.19,4.21],
    "kin3_hms": [2.39,2.41,2.43,2.45,2.47,2.49,2.51,2.53,2.55,2.57,2.59,2.61,2.63,2.65,2.67,2.69,2.71,2.73,2.75,2.77,2.79,2.81,2.83,2.85,2.87,2.89,2.91,2.93,2.95,2.97,2.99,3.01,3.03,3.05,3.07,3.09,3.11,3.13,3.15,3.17,3.19,3.21],
    "kin4_hms": [3.09,3.11,3.13,3.15,3.17,3.19,3.21,3.23,3.25,3.27,3.29,3.31,3.33,3.35,3.37,3.39,3.41,3.43,3.45,3.47,3.49,3.51,3.53,3.55,3.57,3.59,3.61,3.63,3.65,3.67,3.69,3.71,3.73,3.75,3.77,3.79,3.81,3.83,3.85,3.87,3.89,3.91],
}

edges = edges_by_kin[kin]
nbins = len(edges)-1
if idx < 0 or idx >= nbins:
    print(f"ERROR: bin_index {idx} out of range [0, {nbins-1}] for {kin}.", file=sys.stderr)
    sys.exit(3)

emin = edges[idx]
emax = edges[idx+1]
dpp_min = (emin / p_spec_gev - 1.0) * 100.0
dpp_max = (emax / p_spec_gev - 1.0) * 100.0
print(f"{emin} {emax} {dpp_min} {dpp_max} {nbins}")
PY
}

input_file="infiles/${kin}.inp"
if [[ ! -f "$input_file" ]]; then
  echo "ERROR: missing input file $input_file" >&2
  exit 3
fi

read -r p_spec_mev < <(awk 'NR==6{print $1}' "$input_file")
if [[ -z "$p_spec_mev" ]]; then
  echo "ERROR: failed to read spectrometer momentum from $input_file" >&2
  exit 3
fi

read -r eprime_min eprime_max dpp_min dpp_max nbins < <(resolve_bin "$kin" "$bin_index" "$p_spec_mev")

read -r sf_model_flag < <(awk '
  /SF model flag/ {print $1; found=1; exit}
  END {if (!found) print 0}
' "$input_file")
if [[ "$sf_model_flag" == "1" ]]; then
  suffix="3HeFit"
else
  suffix=""
fi

printf 'Resolved setup:\n'
printf '  kin: %s\n' "$kin"
printf '  input: %s\n' "$input_file"
printf '  p_spec: %s MeV/c\n' "$p_spec_mev"
printf '  bin_index: %s / %s\n' "$bin_index" "$((nbins-1))"
printf "  E' range: [%s, %s] GeV\n" "$eprime_min" "$eprime_max"
printf '  dpp range: [%.8f, %.8f] %%\n' "$dpp_min" "$dpp_max"
printf '  MC settings: copied from %s\n' "$input_file"

base_tag="${kin}_bin$(printf '%03d' "$bin_index")"
mc_tag="${base_tag}${suffix}"
temp_input="infiles/${base_tag}.inp"
log_file="runout/${base_tag}.out"
work_root="worksim/${base_tag}.root"
final_root="outfiles/${base_tag}${suffix}.root"

build_once

awk -v dmin="$dpp_min" -v dmax="$dpp_max" '
  NR==8 {$1=sprintf("%.10f", dmin); print; next}
  NR==9 {$1=sprintf("%.10f", dmax); print; next}
  {print}
' "$input_file" > "$temp_input"

(
  cd src
  ./mc_single_arm <<EOF2 |& tee "../${log_file}"
${base_tag}
EOF2
)

(
  cd util/root_tree
  ./make_root_tree <<EOF3
${mc_tag}
EOF3
)

if [[ ! -f "$work_root" ]]; then
  echo "ERROR: missing expected ROOT output $work_root" >&2
  rm -f "$temp_input"
  exit 5
fi

rm -f "$final_root"
mv -f "$work_root" "$final_root"
rm -f "worksim/${mc_tag}.bin" "$temp_input"

echo "Done: wrote ${final_root}"
